PORT=5000
NODE_ENV=production

# Supabase PostgreSQL — copy from Supabase > Settings > Database
DB_HOST=db.xxxxxxxxxxxxxxxxxxxx.supabase.co
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_supabase_db_password
DB_PORT=5432

# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# Your Vercel frontend URL (set after deploying frontend)
FRONTEND_URL=https://your-app.vercel.app

# ML model: set to Hugging Face Space URL after deploying
ML_API_URL=https://your-hf-username-mediscript.hf.space